{
  "version": 2,
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/[...path].js" },
    { "src": "/favicon.ico", "dest": "favicon.ico" },
    { "src": "/css/(.*)", "dest": "css/$1" },
    { "src": "/js/(.*)", "dest": "js/$1" },
    { "src": "/assets/(.*)", "dest": "assets/$1" },
    { "src": "/", "dest": "index.html" },
    { "src": "/(.*)", "dest": "$1" }
  ]
}
